# Copy this file to .env.local for local development (git-ignored).
# Get this value from Google Cloud Console -> APIs & Services -> Credentials
# -> OAuth Client ID -> Web application. It's a public identifier, not a
# secret, but still keep it out of source control for cleanliness.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Base URL of the Django backend's API (no trailing slash). Defaults to
# http://localhost:8000/api/v1 if unset.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Base URL of the Django backend's catalog API (no trailing slash). Defaults
# to http://localhost:8000/catalog/v1 if unset.
NEXT_PUBLIC_CATALOG_BASE_URL=http://localhost:8000/catalog/v1
