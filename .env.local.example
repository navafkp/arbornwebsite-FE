# Copy this file to .env.local for local development (git-ignored).
# Get this value from Google Cloud Console -> APIs & Services -> Credentials
# -> OAuth Client ID -> Web application. It's a public identifier, not a
# secret, but still keep it out of source control for cleanliness.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Base URL of the Django accounts API (no trailing slash).
NEXT_PUBLIC_ACCOUNTS_BASE_URL=https://api.arborn.shop/accounts/v1

# Base URL of the Django catalog API (no trailing slash).
NEXT_PUBLIC_CATALOG_BASE_URL=https://api.arborn.shop/catalog/v1
